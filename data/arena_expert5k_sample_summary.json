{
  "dataset": "lmarena-ai/arena-expert-5k",
  "split": "train",
  "allowed_languages": [
    "en"
  ],
  "judge_model": "gpt-4.1-mini",
  "min_confidence": 0.7,
  "max_workers": 8,
  "coding": {
    "output": "data/v1_coding_500.jsonl",
