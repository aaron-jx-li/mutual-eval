    "target": 500
  },
  "math": {
    "output": "data/v1_math_200.jsonl",
    "count": 200,
    "target": 200,
    "extra_tags": []
  },
  "generic": {
    "output": "data/v1_misc_300.jsonl",
    "count": 300,
    "target": 300
  }
}